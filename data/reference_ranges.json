        {"test": "Diagnosis", "value": "ONE or more values met or exceeded = GDM", "units": "criterion"},
        {"test": "Timing of screening OGTT", "value": "24 - 28 weeks gestation (earlier if high-risk)", "units": "criterion"},
        {"test": "Early OGTT indication", "value": "Booking visit - previous GDM, BMI > 30, PCOS, family hx DM, ethnicity, prior macrosomia, glycosuria", "units": "criterion"},
        {"test": "Overt diabetes in pregnancy", "value": "Fasting >= 7.0 or random >= 11.1 or HbA1c >= 6.5% - manage as pre-existing DM", "units": "criterion"}
      ],
      "notes": "Australian ADIPS criteria (adopted from IADPSG/WHO 2013). One abnormal value is diagnostic in pregnancy (contrast non-pregnant)."
    },
    "beta_hcg_pregnancy": {
      "label": "Beta-hCG in early pregnancy",
      "ranges": [
        {"test": "Non-pregnant", "value": "< 5 IU/L", "units": "IU/L"},
        {"test": "Indeterminate", "value": "5 - 25 IU/L (repeat in 48 h)", "units": "IU/L"},
        {"test": "3 weeks (1 week post-conception)", "value": "5 - 50 IU/L", "units": "IU/L"},
        {"test": "4 weeks (2 weeks post-conception)", "value": "5 - 425 IU/L", "units": "IU/L"},
        {"test": "5 weeks", "value": "20 - 7,300 IU/L", "units": "IU/L"},
        {"test": "6 weeks", "value": "1,000 - 56,000 IU/L", "units": "IU/L"},
        {"test": "7 - 8 weeks", "value": "7,650 - 230,000 IU/L", "units": "IU/L"},
        {"test": "9 - 12 weeks (peak)", "value": "25,000 - 290,000 IU/L", "units": "IU/L"},
        {"test": "T2 / T3", "value": "Falls to 4,000 - 50,000 IU/L plateau", "units": "IU/L"},
        {"test": "Doubling time (normal early IUP)", "value": "48 - 72 h until 6 - 7 weeks; minimum acceptable 53% rise in 48 h", "units": "criterion"},
        {"test": "Discriminatory zone (TVUS)", "value": ">= 1,500 - 2,000 IU/L - IUP should be visible; absence raises ectopic suspicion", "units": "IU/L"},
        {"test": "Suboptimal rise (< 53% over 48 h)", "value": "Suggests failing IUP or ectopic", "units": "criterion"},
        {"test": "Molar pregnancy", "value": "Markedly elevated (often > 100,000) for gestation; snowstorm USS", "units": "criterion"}
      ],
      "notes": "Wide ranges - serial trend more useful than single value. Discriminatory zone is institution-specific (1500 IU/L common in Australian EDs)."
    },
    "obs_pregnancy_vitals": {
      "label": "Normal physiological changes in pregnancy",
      "ranges": [
        {"test": "Cardiac output", "value": "Rises 30 - 50% by 24 weeks", "units": "change"},
        {"test": "Heart rate", "value": "Rises 10 - 20 bpm by T3", "units": "bpm"},
        {"test": "Blood pressure", "value": "Falls in T2 (nadir approximately 24 weeks); returns to baseline by term", "units": "change"},
        {"test": "Plasma volume", "value": "Rises approximately 50%; red cell mass rises approximately 25% - dilutional anaemia", "units": "change"},
        {"test": "Hb (T3 lower limit)", "value": "> 105 g/L (RANZCOG); investigate iron / B12 / folate if lower", "units": "g/L"},
        {"test": "WCC", "value": "Rises to 6 - 16 x10^9/L (neutrophilia); up to 25 x10^9/L peripartum normal", "units": "x10^9/L"},
        {"test": "Platelets", "value": "Falls 10 - 20% (gestational thrombocytopaenia); investigate if < 100", "units": "x10^9/L"},
        {"test": "Respiratory rate", "value": "Mild rise (progesterone-driven hyperventilation)", "units": "change"},
        {"test": "pCO2 / HCO3 (ABG)", "value": "Compensated respiratory alkalosis: pCO2 approximately 30 mmHg, HCO3 18 - 21 mmol/L", "units": "criterion"},
        {"test": "Creatinine", "value": "Falls (upper limit approximately 75 micromol/L by T3) due to rising GFR", "units": "micromol/L"},
        {"test": "Urea", "value": "Falls (upper approximately 4.5 mmol/L)", "units": "mmol/L"},
        {"test": "ALP", "value": "Rises 2 - 4x ULN (placental); physiological", "units": "U/L"},
        {"test": "Albumin", "value": "Falls 5 - 10 g/L (dilutional)", "units": "g/L"},
        {"test": "Fibrinogen", "value": "Rises to 4 - 6 g/L (hypercoagulable)", "units": "g/L"},
        {"test": "D-dimer", "value": "Rises throughout pregnancy - non-pregnant cutoff invalid", "units": "criterion"},
        {"test": "TSH", "value": "Falls in T1 (hCG cross-reactivity)", "units": "criterion"}
      ],
      "notes": "Knowing what is physiological prevents over-investigation. RANZCOG / Williams Obstetrics."
    },
    "pre_eclampsia_bloods": {
      "label": "Pre-eclampsia - diagnostic criteria & severe features",
      "ranges": [
        {"test": "BP threshold", "value": ">= 140/90 mmHg on 2 occasions >= 4 h apart, after 20 weeks gestation, in a previously normotensive woman", "units": "criterion"},
        {"test": "Severe BP", "value": ">= 160/110 mmHg", "units": "criterion"},
        {"test": "Proteinuria", "value": ">= 300 mg / 24 h OR spot protein:creatinine ratio >= 30 mg/mmol OR dipstick >= 2+", "units": "criterion"},
        {"test": "Platelets (end-organ)", "value": "< 100 x10^9/L", "units": "x10^9/L"},
        {"test": "Creatinine (end-organ)", "value": "> 90 micromol/L OR doubling of baseline", "units": "micromol/L"},
        {"test": "ALT / AST (end-organ)", "value": "> 2 x ULN (i.e. > 70 U/L)", "units": "U/L"},
        {"test": "Neurological features", "value": "Severe headache, visual disturbance, hyperreflexia, clonus, eclamptic seizure", "units": "criterion"},
        {"test": "Pulmonary oedema", "value": "Clinical / imaging - severe feature", "units": "criterion"},
        {"test": "Uteroplacental dysfunction", "value": "FGR, oligohydramnios, abnormal umbilical artery Doppler, stillbirth", "units": "criterion"},
        {"test": "HELLP syndrome", "value": "Haemolysis (LDH > 600, schistocytes), Elevated Liver enzymes (AST > 70), Low Platelets (< 100)", "units": "criterion"},
        {"test": "Diagnostic combination", "value": "Hypertension (after 20 wk) PLUS proteinuria OR any end-organ dysfunction", "units": "criterion"},
        {"test": "Eclampsia", "value": "Tonic-clonic seizure in pregnancy/postpartum with pre-eclampsia features", "units": "criterion"}
      ],
      "notes": "SOMANZ / RANZCOG criteria. Magnesium sulfate is the anticonvulsant of choice (4 g loading, 1 g/h maintenance). Definitive treatment = delivery of placenta."
    },
    "ctg_baseline": {
      "label": "Cardiotocograph (CTG) - normal & FIGO classification",
      "ranges": [
        {"test": "Baseline FHR (normal)", "value": "110 - 160 bpm", "units": "bpm"},
        {"test": "Baseline FHR (tachycardia)", "value": "> 160 bpm for > 10 min", "units": "bpm"},
        {"test": "Baseline FHR (bradycardia)", "value": "< 110 bpm for > 10 min", "units": "bpm"},
        {"test": "Variability (normal)", "value": "5 - 25 bpm", "units": "bpm"},
        {"test": "Variability (reduced)", "value": "< 5 bpm for > 40 min", "units": "criterion"},
        {"test": "Variability (absent)", "value": "Amplitude undetectable - pre-terminal", "units": "criterion"},
        {"test": "Accelerations", "value": "Rise >= 15 bpm for >= 15 sec (term); reassuring, not required for normal CTG", "units": "criterion"},
        {"test": "Early decelerations", "value": "Mirror contractions; nadir with peak of contraction; vagal response to head compression; benign", "units": "pattern"},
        {"test": "Variable decelerations", "value": "Abrupt drop (>= 15 bpm, >= 15 sec); cord compression; concerning if recurrent, > 60 sec, or > 60 bpm below baseline", "units": "pattern"},
        {"test": "Late decelerations", "value": "Nadir after contraction peak; uteroplacental insufficiency; pathological", "units": "pattern"},
        {"test": "Prolonged deceleration", "value": "Drop >= 15 bpm for > 3 min (< 10 min); urgent assessment", "units": "criterion"},
        {"test": "FIGO Normal", "value": "Baseline 110 - 160, variability 5 - 25, no repetitive late/prolonged decels", "units": "category"},
        {"test": "FIGO Suspicious", "value": "Lacking 1 normal feature but no pathological features", "units": "category"},
        {"test": "FIGO Pathological", "value": ">= 2 of: baseline abnormality, reduced variability, repetitive late/prolonged decels; or sinusoidal pattern", "units": "category"},
        {"test": "Sinusoidal pattern", "value": "Smooth sine wave, 3 - 5 cycles/min, > 30 min - severe fetal anaemia / hypoxia", "units": "criterion"}
      ],
      "notes": "DR C BRAVADO mnemonic: DR (define risk), C (contractions), BRa (baseline rate), V (variability), A (accelerations), D (decelerations), O (overall). FIGO 2015 classification."
    },
    "apgar": {
      "label": "Apgar score (newborn)",
      "ranges": [
        {"test": "Heart rate", "value": "0 = absent / 1 = < 100 bpm / 2 = >= 100 bpm", "units": "score"},
        {"test": "Respiratory effort", "value": "0 = absent / 1 = slow, irregular / 2 = good, crying", "units": "score"},
        {"test": "Muscle tone", "value": "0 = flaccid / 1 = some flexion / 2 = active motion", "units": "score"},
        {"test": "Reflex irritability (suction/stimulation)", "value": "0 = no response / 1 = grimace / 2 = cry, cough, sneeze", "units": "score"},
        {"test": "Colour", "value": "0 = blue / pale / 1 = body pink, extremities blue (acrocyanosis) / 2 = pink all over", "units": "score"},
        {"test": "Timing", "value": "Assessed at 1 minute AND 5 minutes; repeat at 10 min if < 7 at 5 min", "units": "criterion"},
        {"test": "Score >= 7", "value": "Normal", "units": "category"},
        {"test": "Score 4 - 6", "value": "Moderately depressed", "units": "category"},
        {"test": "Score < 4", "value": "Severely depressed - active resuscitation", "units": "category"}
      ],
      "notes": "Apgar is a descriptive tool, NOT a resuscitation trigger - resuscitate based on HR / tone / breathing within 30 sec of birth. 5-min Apgar < 7 prompts neonatal review."
    },
    "bishop_score": {
      "label": "Bishop score (cervical favourability for induction)",
      "ranges": [
        {"test": "Dilation - 0 points", "value": "Closed", "units": "score"},
        {"test": "Dilation - 1", "value": "1 - 2 cm", "units": "score"},
        {"test": "Dilation - 2", "value": "3 - 4 cm", "units": "score"},
        {"test": "Dilation - 3", "value": ">= 5 cm", "units": "score"},
        {"test": "Effacement - 0", "value": "0 - 30%", "units": "score"},
        {"test": "Effacement - 1", "value": "40 - 50%", "units": "score"},
        {"test": "Effacement - 2", "value": "60 - 70%", "units": "score"},
        {"test": "Effacement - 3", "value": ">= 80%", "units": "score"},
        {"test": "Station - 0", "value": "-3", "units": "score"},
        {"test": "Station - 1", "value": "-2", "units": "score"},
        {"test": "Station - 2", "value": "-1 / 0", "units": "score"},
        {"test": "Station - 3", "value": "+1 / +2", "units": "score"},
        {"test": "Consistency - 0", "value": "Firm", "units": "score"},
        {"test": "Consistency - 1", "value": "Medium", "units": "score"},
        {"test": "Consistency - 2", "value": "Soft", "units": "score"},
        {"test": "Position - 0", "value": "Posterior", "units": "score"},
        {"test": "Position - 1", "value": "Mid", "units": "score"},
        {"test": "Position - 2", "value": "Anterior", "units": "score"},
        {"test": "Total score - favourable", "value": ">= 8 (induction success similar to spontaneous labour)", "units": "category"},
        {"test": "Total score - unfavourable", "value": "<= 6 (consider cervical ripening: prostaglandins, balloon catheter)", "units": "category"}
      ],
      "notes": "Maximum 13. Higher score = more favourable cervix. RANZCOG / Williams Obstetrics."
    },
    "gcs": {
      "label": "Glasgow Coma Scale (adult + paediatric)",
      "ranges": [
        {"test": "Eye opening (E) - 4", "value": "Spontaneous", "units": "score"},
        {"test": "Eye opening (E) - 3", "value": "To voice", "units": "score"},
        {"test": "Eye opening (E) - 2", "value": "To pain", "units": "score"},
        {"test": "Eye opening (E) - 1", "value": "None", "units": "score"},
        {"test": "Verbal (V) adult - 5", "value": "Oriented", "units": "score"},
        {"test": "Verbal (V) adult - 4", "value": "Confused conversation", "units": "score"},
        {"test": "Verbal (V) adult - 3", "value": "Inappropriate words", "units": "score"},
        {"test": "Verbal (V) adult - 2", "value": "Incomprehensible sounds", "units": "score"},
        {"test": "Verbal (V) adult - 1", "value": "None", "units": "score"},
        {"test": "Verbal (V) paeds (< 2 y) - 5", "value": "Coos, babbles, smiles", "units": "score"},
        {"test": "Verbal (V) paeds - 4", "value": "Cries, consolable", "units": "score"},
        {"test": "Verbal (V) paeds - 3", "value": "Cries to pain", "units": "score"},
        {"test": "Verbal (V) paeds - 2", "value": "Moans to pain", "units": "score"},
        {"test": "Verbal (V) paeds - 1", "value": "None", "units": "score"},
        {"test": "Motor (M) - 6", "value": "Obeys commands (or spontaneous movements in infant)", "units": "score"},
        {"test": "Motor (M) - 5", "value": "Localises to pain", "units": "score"},
        {"test": "Motor (M) - 4", "value": "Withdraws from pain", "units": "score"},
        {"test": "Motor (M) - 3", "value": "Abnormal flexion (decorticate)", "units": "score"},
        {"test": "Motor (M) - 2", "value": "Abnormal extension (decerebrate)", "units": "score"},
        {"test": "Motor (M) - 1", "value": "None", "units": "score"},
        {"test": "GCS <= 8", "value": "Threshold for intubation (loss of airway protection)", "units": "criterion"},
        {"test": "Total range", "value": "3 (deep coma) to 15 (fully alert)", "units": "category"}
      ],
      "notes": "Report as E_V_M_ = total (e.g. E3V4M5 = 12). Trend matters more than absolute score. Intubated patient: V documented as 'T' (tube)."
    },
    "lipids": {
      "label": "Lipid profile (adult, fasting)",
      "ranges": [
        {"test": "Total cholesterol", "value": "< 5.5 mmol/L (desirable)", "units": "mmol/L"},
        {"test": "LDL cholesterol", "value": "< 2.0 mmol/L (high CV risk) / < 3.5 mmol/L (general)", "units": "mmol/L"},
        {"test": "HDL cholesterol (female)", "value": "> 1.3 mmol/L", "units": "mmol/L"},
        {"test": "HDL cholesterol (male)", "value": "> 1.0 mmol/L", "units": "mmol/L"},
        {"test": "Triglycerides", "value": "< 2.0 mmol/L (fasting)", "units": "mmol/L"},
        {"test": "Triglycerides - severe (pancreatitis risk)", "value": "> 10 mmol/L", "units": "mmol/L"},
        {"test": "Non-HDL cholesterol", "value": "< 2.5 mmol/L (high CV risk)", "units": "mmol/L"}
      ],
      "notes": "Australian CVD risk calculator (CVDcheck) drives targets, not absolute values. Familial hypercholesterolaemia suspected if LDL > 5.0 mmol/L untreated. Pregnancy raises all lipids physiologically."
    },
    "calcium_corrected": {
      "label": "Calcium, magnesium, phosphate",
      "ranges": [
        {"test": "Total calcium", "value": "2.10 - 2.60 mmol/L", "units": "mmol/L"},
        {"test": "Ionised calcium", "value": "1.15 - 1.30 mmol/L", "units": "mmol/L"},
        {"test": "Corrected calcium formula", "value": "Corrected Ca = measured Ca + 0.02 x (40 - albumin g/L)", "units": "formula"},
        {"test": "Magnesium", "value": "0.7 - 1.1 mmol/L", "units": "mmol/L"},
        {"test": "Phosphate (adult)", "value": "0.75 - 1.50 mmol/L", "units": "mmol/L"},
        {"test": "Phosphate (child)", "value": "1.0 - 2.0 mmol/L (higher than adult; bone growth)", "units": "mmol/L"},
        {"test": "PTH", "value": "1.6 - 6.9 pmol/L", "units": "pmol/L"},
        {"test": "25-OH vitamin D - deficient", "value": "< 30 nmol/L", "units": "nmol/L"},
        {"test": "25-OH vitamin D - insufficient", "value": "30 - 50 nmol/L", "units": "nmol/L"},
        {"test": "25-OH vitamin D - sufficient", "value": ">= 50 nmol/L (end winter); >= 60 (other seasons)", "units": "nmol/L"}
      ],
      "notes": "Always interpret calcium alongside albumin (or use ionised). Severe hypocalcaemia (< 1.9 mmol/L) - check for Chvostek / Trousseau, ECG (long QT). MgSO4 used for both eclampsia prophylaxis and for paeds severe asthma."
    },
    "inflammatory_markers": {
      "label": "Inflammatory markers",
      "ranges": [
        {"test": "CRP", "value": "< 5 mg/L (normal); > 100 mg/L suggests bacterial infection", "units": "mg/L"},
        {"test": "ESR (female)", "value": "< 20 mm/h (rises with age and pregnancy)", "units": "mm/h"},
        {"test": "ESR (male)", "value": "< 15 mm/h", "units": "mm/h"},
        {"test": "ESR - age-adjusted upper limit (Miller)", "value": "Female: (age + 10) / 2; Male: age / 2", "units": "formula"},
        {"test": "Procalcitonin", "value": "< 0.5 microg/L (normal); > 2.0 = high probability bacterial sepsis", "units": "microg/L"},
        {"test": "Ferritin (acute phase)", "value": "> 500 microg/L in inflammation; > 10,000 raises HLH / Still's", "units": "microg/L"}
      ],
      "notes": "CRP peaks at 48 h - early infection may have normal CRP. ESR is non-specific; rises in pregnancy, anaemia, multiple myeloma. Procalcitonin variably available in Australia."
    },
    "coags": {
      "label": "Coagulation studies",
      "ranges": [
        {"test": "INR (off anticoagulation)", "value": "0.9 - 1.2", "units": "ratio"},
        {"test": "INR target - AF / DVT-PE on warfarin", "value": "2.0 - 3.0", "units": "ratio"},
        {"test": "INR target - mechanical mitral valve", "value": "2.5 - 3.5", "units": "ratio"},
        {"test": "APTT", "value": "26 - 38 seconds", "units": "seconds"},
        {"test": "APTT - therapeutic UFH", "value": "1.5 - 2.5 x baseline", "units": "ratio"},
        {"test": "Fibrinogen", "value": "2.0 - 4.0 g/L (non-pregnant); 4.0 - 6.0 g/L (T3 pregnancy)", "units": "g/L"},
        {"test": "Fibrinogen - postpartum haemorrhage", "value": "< 2.0 g/L predicts severe PPH - replace with cryoprecipitate", "units": "criterion"},
        {"test": "D-dimer (non-pregnant)", "value": "< 0.5 mg/L (age-adjusted: age x 10 microg/L over 50)", "units": "mg/L"},
        {"test": "Thrombin time", "value": "14 - 21 seconds", "units": "seconds"}
      ],
      "notes": "PT/INR reflects extrinsic + common (Factors II, V, VII, X). APTT reflects intrinsic + common (VIII, IX, XI, XII, II, V, X). Mixing studies differentiate factor deficiency vs inhibitor."
    },
    "vitamins": {
      "label": "Vitamins B12, folate, D",
      "ranges": [
        {"test": "Vitamin B12", "value": "150 - 700 pmol/L (deficient < 150; borderline 150 - 220)", "units": "pmol/L"},
        {"test": "Active B12 (holotranscobalamin)", "value": "> 50 pmol/L (where available)", "units": "pmol/L"},
        {"test": "Methylmalonic acid (functional B12 deficiency)", "value": "< 0.27 micromol/L", "units": "micromol/L"},
        {"test": "Serum folate", "value": "> 7 nmol/L (deficient < 7)", "units": "nmol/L"},
        {"test": "Red cell folate", "value": "> 360 nmol/L", "units": "nmol/L"},
        {"test": "25-OH vitamin D (sufficient)", "value": ">= 50 nmol/L", "units": "nmol/L"},
        {"test": "25-OH vitamin D (deficient)", "value": "< 30 nmol/L", "units": "nmol/L"},
        {"test": "Folate - preconception supplementation", "value": "500 microg/day from 1 month pre-conception; 5 mg/day if high-risk (prior NTD, diabetes, anticonvulsants, BMI > 30)", "units": "criterion"}
      ],
      "notes": "Check B12 before treating folate deficiency (B12 deficiency can be masked and SCDC worsened). Vitamin D deficiency common in Australia despite latitude - veiled women, dark skin, institutionalised."
    }
  },
