    "paeds_uec": {
      "label": "Paediatric U&E by age band",
      "ranges": [
        {"test": "Sodium (all paeds ages)", "value": "135 - 145 mmol/L", "units": "mmol/L"},
        {"test": "Potassium - neonate", "value": "3.5 - 6.0 mmol/L", "units": "mmol/L"},
        {"test": "Potassium - infant / child", "value": "3.5 - 5.5 mmol/L", "units": "mmol/L"},
        {"test": "Chloride", "value": "95 - 110 mmol/L", "units": "mmol/L"},
        {"test": "Bicarbonate - infant", "value": "18 - 25 mmol/L", "units": "mmol/L"},
        {"test": "Bicarbonate - child", "value": "22 - 28 mmol/L", "units": "mmol/L"},
        {"test": "Urea - infant / child", "value": "1.5 - 6.5 mmol/L", "units": "mmol/L"},
        {"test": "Creatinine - neonate (term, day 3 - 7)", "value": "20 - 75 micromol/L", "units": "micromol/L"},
        {"test": "Creatinine - 1 month to 1 year", "value": "15 - 35 micromol/L", "units": "micromol/L"},
        {"test": "Creatinine - 1 - 5 years", "value": "20 - 40 micromol/L", "units": "micromol/L"},
        {"test": "Creatinine - 5 - 12 years", "value": "30 - 60 micromol/L", "units": "micromol/L"},
        {"test": "Creatinine - adolescent", "value": "45 - 90 micromol/L (approaches adult by Tanner V)", "units": "micromol/L"}
      ],
      "notes": "Creatinine reflects muscle mass; rises through childhood. Schwartz formula (k x height / creatinine) used for paediatric eGFR. RCH / RCPA paediatric intervals."
    },
    "lfts": {
      "label": "Liver Function Tests (adult)",
      "ranges": [
        {"test": "Bilirubin (total)", "value": "< 20 micromol/L", "units": "micromol/L"},
        {"test": "Bilirubin (direct / conjugated)", "value": "< 5 micromol/L", "units": "micromol/L"},
        {"test": "ALT", "value": "< 35 U/L (F) / < 45 U/L (M)", "units": "U/L"},
        {"test": "AST", "value": "< 35 U/L", "units": "U/L"},
        {"test": "ALP", "value": "30 - 110 U/L (adult)", "units": "U/L"},
        {"test": "GGT (female)", "value": "< 35 U/L", "units": "U/L"},
        {"test": "GGT (male)", "value": "< 50 U/L", "units": "U/L"},
        {"test": "Albumin", "value": "35 - 50 g/L", "units": "g/L"},
        {"test": "Total protein", "value": "60 - 80 g/L", "units": "g/L"}
      ],
      "notes": "Pregnancy: ALP rises 2 - 4x ULN (placental isoenzyme) by T3 - this is physiological. Albumin falls approximately 5 - 10 g/L in pregnancy. Children have higher ALP (bone isoenzyme) - up to 500 U/L pre-puberty is normal."
    },
    "paeds_jaundice": {
      "label": "Neonatal jaundice - phototherapy thresholds (summary)",
      "ranges": [
        {"test": "Approximate phototherapy threshold - term healthy, 24 h", "value": "approximately 220 micromol/L", "units": "micromol/L"},
        {"test": "Approximate phototherapy threshold - term healthy, 48 h", "value": "approximately 280 micromol/L", "units": "micromol/L"},
        {"test": "Approximate phototherapy threshold - term healthy, 72 h", "value": "approximately 300 - 340 micromol/L", "units": "micromol/L"},
        {"test": "Approximate phototherapy threshold - term healthy, 96 h+", "value": "approximately 340 - 380 micromol/L", "units": "micromol/L"},
        {"test": "Exchange transfusion threshold - term healthy, > 72 h", "value": "approximately 430 - 480 micromol/L", "units": "micromol/L"},
        {"test": "Conjugated fraction red flag", "value": "> 15% of total OR > 25 micromol/L direct - always pathological, investigate biliary atresia", "units": "criterion"},
        {"test": "Jaundice < 24 h of life", "value": "Always pathological - urgent investigation (haemolysis, sepsis)", "units": "criterion"}
      ],
      "notes": "Thresholds are gestational-age, postnatal-age and risk-factor specific - use the RCH Neonatal Jaundice nomogram or NICE chart. Prolonged jaundice = > 14 days term or > 21 days preterm - investigate. Values here are approximate anchors only."
    },
    "abg": {
      "label": "Arterial Blood Gas (adult, room air)",
      "ranges": [
        {"test": "pH", "value": "7.35 - 7.45", "units": "pH units"},
        {"test": "pCO2", "value": "4.7 - 6.0 kPa (35 - 45 mmHg)", "units": "kPa / mmHg"},
        {"test": "pO2", "value": "10.6 - 13.3 kPa (80 - 100 mmHg)", "units": "kPa / mmHg"},
        {"test": "HCO3 (actual)", "value": "22 - 26 mmol/L", "units": "mmol/L"},
        {"test": "Base excess", "value": "-2 to +2 mmol/L", "units": "mmol/L"},
        {"test": "Lactate", "value": "0.5 - 2.0 mmol/L (arterial)", "units": "mmol/L"},
        {"test": "Anion gap (Na - (Cl + HCO3))", "value": "8 - 16 mmol/L (without K), 10 - 20 (with K)", "units": "mmol/L"},
        {"test": "SaO2", "value": "95 - 100 %", "units": "%"},
        {"test": "A-a gradient (young adult)", "value": "< 15 mmHg (rises approximately 1 mmHg per decade)", "units": "mmHg"}
      ],
      "notes": "Australian labs typically report pCO2/pO2 in mmHg; both shown. Pregnancy: compensated respiratory alkalosis is normal (pCO2 approximately 30 mmHg, HCO3 approximately 18 - 21)."
    },
    "vbg": {
      "label": "Venous Blood Gas (adult, peripheral)",
      "ranges": [
        {"test": "pH", "value": "7.31 - 7.41 (0.03 - 0.05 lower than arterial)", "units": "pH units"},
        {"test": "pCO2", "value": "5.5 - 6.8 kPa (41 - 51 mmHg; approximately 6 mmHg higher than arterial)", "units": "kPa / mmHg"},
        {"test": "HCO3", "value": "22 - 28 mmol/L (approximately 1 - 2 higher than arterial)", "units": "mmol/L"},
        {"test": "Lactate (peripheral venous)", "value": "0.5 - 2.2 mmol/L", "units": "mmol/L"},
        {"test": "Base excess", "value": "-2 to +2 mmol/L (similar to arterial)", "units": "mmol/L"}
      ],
      "notes": "VBG correlates well with ABG for pH, HCO3, base excess and lactate. pCO2 less reliable - confirm with ABG if respiratory failure suspected. pO2 not interpretable on VBG."
    },
    "bsl_paeds": {
      "label": "Paediatric blood glucose & hypoglycaemia",
      "ranges": [
        {"test": "Normal BSL (child / adolescent, fasting)", "value": "3.5 - 5.5 mmol/L", "units": "mmol/L"},
        {"test": "Normal BSL (child, random / postprandial)", "value": "< 7.8 mmol/L", "units": "mmol/L"},
        {"test": "Hypoglycaemia - neonate (operational threshold)", "value": "< 2.6 mmol/L", "units": "mmol/L"},
        {"test": "Hypoglycaemia - infant / child", "value": "< 3.3 mmol/L (symptomatic) or < 2.6 (definite)", "units": "mmol/L"},
        {"test": "DKA diagnostic threshold (BSL)", "value": ">= 11.0 mmol/L PLUS ketosis PLUS acidosis (pH < 7.3 or HCO3 < 15)", "units": "mmol/L"},
        {"test": "Euglycaemic DKA", "value": "Can occur with BSL < 11 - especially partial insulin, SGLT2i, pregnancy", "units": "criterion"}
      ],
      "notes": "Neonatal threshold 2.6 mmol/L is operational (ISPAD / RCH). Send 'hypo screen' (insulin, C-peptide, cortisol, GH, lactate, ammonia, ketones, free fatty acids, acylcarnitines, urine organic acids) at the time of hypoglycaemia, before treatment."
    },
    "ketones": {
      "label": "Capillary blood ketones (beta-hydroxybutyrate)",
      "ranges": [
        {"test": "Normal", "value": "< 0.6 mmol/L", "units": "mmol/L"},
        {"test": "Mild ketosis / caution", "value": "0.6 - 1.5 mmol/L", "units": "mmol/L"},
        {"test": "Significant ketosis / risk of DKA", "value": "1.5 - 3.0 mmol/L", "units": "mmol/L"},
        {"test": "DKA criterion (with hyperglycaemia + acidosis)", "value": ">= 3.0 mmol/L", "units": "mmol/L"}
      ],
      "notes": "Beta-hydroxybutyrate is the dominant ketone in DKA; urine ketones (acetoacetate) lag behind and persist after resolution. Capillary blood ketones preferred for monitoring."
    },
    "csf": {
      "label": "Cerebrospinal Fluid (adult)",
      "ranges": [
        {"test": "Opening pressure", "value": "7 - 18 cmH2O (lateral decubitus)", "units": "cmH2O"},
        {"test": "Appearance", "value": "Clear, colourless ('gin clear')", "units": "qualitative"},
        {"test": "WCC", "value": "< 5 x10^6/L (all lymphocytes/monocytes)", "units": "x10^6/L"},
        {"test": "Neutrophils", "value": "0 x10^6/L (any neutrophils abnormal in adult)", "units": "x10^6/L"},
        {"test": "Protein", "value": "0.15 - 0.45 g/L", "units": "g/L"},
        {"test": "Glucose", "value": "2.5 - 4.5 mmol/L (CSF:plasma ratio > 0.6)", "units": "mmol/L"},
        {"test": "Bacterial meningitis pattern", "value": "Cloudy; WCC 100 - 5000 (neutrophil predominant); protein > 1.0 g/L; glucose < 2.2 mmol/L (CSF:plasma < 0.4); Gram stain positive in 60 - 90%", "units": "pattern"},
        {"test": "Viral meningitis pattern", "value": "Clear; WCC 10 - 500 (lymphocyte predominant); protein < 1.0 g/L; glucose normal", "units": "pattern"},
        {"test": "TB / fungal meningitis pattern", "value": "Clear or fibrinous; WCC 100 - 500 (lymphocyte predominant); protein 1.0 - 5.0 g/L; glucose low (< 2.2 mmol/L)", "units": "pattern"},
        {"test": "SAH pattern", "value": "Xanthochromia after 12 h; equal RBC in all bottles; opening pressure may be elevated", "units": "pattern"}
      ],
      "notes": "CSF:plasma glucose ratio more reliable than absolute glucose. Send paired serum glucose at LP. Traumatic tap: RBC falls between bottles; xanthochromia absent."
    },
    "csf_paeds_specific": {
      "label": "CSF reference - paediatric (especially neonate)",
      "ranges": [
        {"test": "WCC - term neonate (< 28 days)", "value": "< 20 x10^6/L (upper acceptable approximately 20 - 22)", "units": "x10^6/L"},
        {"test": "WCC - preterm neonate", "value": "< 25 x10^6/L", "units": "x10^6/L"},
        {"test": "WCC - 1 - 12 months", "value": "< 10 x10^6/L", "units": "x10^6/L"},
        {"test": "WCC - > 1 year", "value": "< 5 x10^6/L (adult)", "units": "x10^6/L"},
        {"test": "Protein - term neonate", "value": "< 1.0 g/L (up to 1.5 acceptable)", "units": "g/L"},
        {"test": "Protein - preterm neonate", "value": "< 1.5 g/L", "units": "g/L"},
        {"test": "Protein - > 1 month", "value": "< 0.45 g/L", "units": "g/L"},
        {"test": "Glucose - neonate", "value": "1.5 - 5.5 mmol/L (CSF:plasma > 0.6)", "units": "mmol/L"},
        {"test": "Neonatal meningitis - empiric Abx", "value": "Cefotaxime + ampicillin + aciclovir until HSV excluded", "units": "criterion"}
      ],
      "notes": "Neonatal CSF normally has higher WCC and protein than adult - do not over-call meningitis. Any neutrophils in neonatal CSF is concerning. Traumatic tap correction in neonates is unreliable - if uncertain, treat. RCH neonatal guideline."
    },
