    "glucose_hba1c": {
      "label": "Glucose, OGTT, HbA1c (non-pregnant adult)",
      "ranges": [
        {"test": "Fasting glucose - normal", "value": "3.5 - 5.5 mmol/L", "units": "mmol/L"},
        {"test": "Impaired fasting glucose (IFG)", "value": "5.6 - 6.9 mmol/L", "units": "mmol/L"},
        {"test": "Fasting glucose - diabetes", "value": ">= 7.0 mmol/L (on 2 occasions or with symptoms)", "units": "mmol/L"},
        {"test": "Random glucose - diabetes", "value": ">= 11.1 mmol/L with symptoms", "units": "mmol/L"},
        {"test": "OGTT 2-h - normal", "value": "< 7.8 mmol/L", "units": "mmol/L"},
        {"test": "OGTT 2-h - impaired glucose tolerance (IGT)", "value": "7.8 - 11.0 mmol/L", "units": "mmol/L"},
        {"test": "OGTT 2-h - diabetes", "value": ">= 11.1 mmol/L", "units": "mmol/L"},
        {"test": "HbA1c - normal", "value": "< 5.7 % (< 39 mmol/mol)", "units": "% / mmol/mol"},
        {"test": "HbA1c - prediabetes", "value": "5.7 - 6.4 % (39 - 47 mmol/mol)", "units": "% / mmol/mol"},
        {"test": "HbA1c - diabetes diagnostic", "value": ">= 6.5 % (>= 48 mmol/mol)", "units": "% / mmol/mol"},
        {"test": "HbA1c - T1DM target", "value": "<= 7.0 % (<= 53 mmol/mol)", "units": "% / mmol/mol"}
